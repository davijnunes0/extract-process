# --- PostgreSQL --------------------------------------------------------------
# No Docker, db-init/aurora-backend recebem DB_* do compose; local: ajustar host.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=processos_ifg
DB_USER=admin
DB_PASS=admin

# --- API FastAPI ---------------------------------------------------------------
LOG_LEVEL=INFO
# Produção (docker-compose.yml — padrão Traefik)
AURORA_PUBLIC_HOST=aurora.ifg.edu.br
ALLOWED_ORIGINS=https://aurora.ifg.edu.br,http://aurora.ifg.edu.br
DEBUG=0

SEED_ADMIN_ENABLED=1
SEED_ADMIN_EMAIL=admin@ifg.edu.br
SEED_ADMIN_PASSWORD=27052005
SEED_ADMIN_NOME=Administrador

# JWT (commit 0993470a — vazio usa fallback legado em jwt_handler.py)
JWT_SECRET=
JWT_EXPIRA_MINUTOS=480

# --- Carga de dados -----------------------------------------------------------
RELOAD_CSV=0
FORCE_CLEAN=0
CSV_SUBDIR=ifg_csv_padrao_1024_1026_1009_1010_20260526T215001Z
CSV_MERGE_ROOT_WITH_SUBDIR=0
FETCH_BARRAMENTO=1
FETCH_SERVIDORES=1
LOAD_QUALIFICACAO_MANUAL_CSV=0
QUALIFICACAO_MANUAL_CSV_SUBDIR=qualificacao_manual

# --- Extração IA --------------------------------------------------------------
WARMUP_LIMIT=0
WARMUP_SKIP=
WORKER_POLL_INTERVAL=30
WORKER_STALE_PROCESSING_MINUTES=30

# --- Barramento IFG -----------------------------------------------------------
IFG_TOKEN_URL=https://barramento.ifg.edu.br/ifg_barramento_ws/wsrestrita/ifg_produz/ecf655a7-9
