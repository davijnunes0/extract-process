IFG_USER=ifg_produz
IFG_DATASETS=1024,1026,1009,1010,1028
TOKEN_DELAY_SECONDS=0.1
PASSWORD_IFG_ENCRYPTED=gAAAAABpJ7FvKccOfENu82JRgTLzaLyjuY0GMrKSc_A3Owaq_ZN2og5Sf1Q1fzUabux_EmTru_nvDfogPoHs9-4r-K6DgQSLcmOGhUXbXCsihOyEoz8V-Jw=
ENCRYPTION_KEY=mk2MWH1HFFClsP2leOs0EZ6bvnZkZIegkAr96CZTc3Y=
